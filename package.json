{
  "name": "terminus-app",
  "version": "1.0.0",
  "description": "Web-based terminal emulator like Terminus for server management",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:client": "cd client && npm run dev",
    "dev:electron": "cd electron && npm run dev",
    "build": "cd client && npm run build && cd ../electron && npm run build",
    "build:client": "cd client && npm run build",
    "build:electron": "cd electron && npm run build",
    "start": "electron ."
  },
  "keywords": ["terminal", "electron", "ssh", "server-management"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
